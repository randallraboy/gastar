# Force LF line endings in the working tree on every platform.
# The repo's Prettier config defaults to `endOfLine: "lf"`; without this,
# a Windows checkout with core.autocrlf=true produces CRLF and fails
# `prettier --check .` on every file.
* text=auto eol=lf

# Binary assets: never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
