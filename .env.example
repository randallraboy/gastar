# gastar environment variables
#
# Copy this file to `.env.local` for local development (Next.js loads it automatically).
# On Vercel, set the same variables in Project → Settings → Environment Variables.
#
# Never commit real values. `.env`, `.env.local`, and other secret files are gitignored.

# -----------------------------------------------------------------------------
# DATABASE_URL (required)
# Neon Postgres connection string for the app and migration/seed scripts.
#
# Where to get it:
#   Neon console → your project → Connection details → Connection string (psql).
#
# Format:
#   postgres://USER:PASSWORD@HOST/DATABASE?sslmode=require
#
# Used by: Next.js API routes (Drizzle), `npm run db:migrate`, `npm run seed`.
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://user:pass@ep-example-123456.us-east-2.aws.neon.tech/gastar?sslmode=require

# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID (required)
# OAuth 2.0 client ID for Google sign-in (Auth.js).
#
# Where to get it:
#   Google Cloud Console → APIs & Services → Credentials →
#   Create OAuth client ID → Application type: Web application.
#
# Authorized JavaScript origins (add both for local + deployed):
#   http://localhost:3000
#   https://YOUR-APP.vercel.app
#
# Authorized redirect URIs:
#   http://localhost:3000/api/auth/callback/google
#   https://YOUR-APP.vercel.app/api/auth/callback/google
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=

# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_SECRET (required)
# OAuth 2.0 client secret paired with GOOGLE_CLIENT_ID.
#
# Where to get it:
#   Same Google Cloud OAuth client as above (shown once at creation; regenerate if lost).
#
# Keep secret — anyone with this + CLIENT_ID can impersonate your OAuth app.
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# AUTH_SECRET (required)
# Random string used by Auth.js to sign and encrypt session JWTs/cookies.
#
# Generate locally:
#   npx auth secret
#
# Use a different value per environment (local vs production). Minimum 32 characters.
# -----------------------------------------------------------------------------
AUTH_SECRET=

# -----------------------------------------------------------------------------
# ALLOWED_EMAILS (required)
# Comma-separated list of Google accounts permitted to use gastar.
#
# Rules:
#   - Comparison is case-insensitive.
#   - Checked on every sign-in and API request (non-listed Google accounts get 403).
#   - All listed users share one expense ledger (personal app; 1–2 accounts typical).
#
# Example:
#   you@gmail.com,partner@gmail.com
# -----------------------------------------------------------------------------
ALLOWED_EMAILS=you@gmail.com,partner@gmail.com

# -----------------------------------------------------------------------------
# HARNESS_TOKEN (required)
# Shared secret for the owner-run receipt processing harness (local CLI only).
#
# Generate:
#   Any long random string (e.g. `openssl rand -hex 32` or a password manager).
#
# The hosted app never calls third-party AI/OCR — this token lets the local
# `harness/cli.ts` (or `/receipt-harness` skill) call harness-only API routes:
#   GET  /api/receipts?status=pending
#   GET  /api/receipts/{id}/image
#   POST /api/receipts/{id}/result
#
# Sent as: Authorization: Bearer <HARNESS_TOKEN>
# Use the same value locally and on Vercel if you process receipts against production.
# -----------------------------------------------------------------------------
HARNESS_TOKEN=

# -----------------------------------------------------------------------------
# BLOB_READ_WRITE_TOKEN (required)
# Vercel Blob store token for receipt image upload and storage.
#
# Where to get it:
#   Vercel dashboard → Storage → Blob → your store → .env.local tab / token.
#   Or link a Blob store to the project when deploying.
#
# Used when users upload receipt photos (staging queue) and when serving attached images.
# Staged blobs are cleaned up when a receipt is confirmed, discarded, or converted.
# -----------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=

# -----------------------------------------------------------------------------
# GASTAR_URL (harness CLI only — not read by the Next.js app)
# Base URL of the running gastar instance for `npm run harness` / receipt-harness skill.
#
# Examples:
#   GASTAR_URL=http://localhost:3000          # local dev
#   GASTAR_URL=https://your-app.vercel.app      # production
#
# Set in your shell or a separate env file when running the harness; optional in
# `.env.local` if you export it before `npm run harness`.
# -----------------------------------------------------------------------------
